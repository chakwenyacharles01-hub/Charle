# === App ===
PORT=3000
SESSION_SECRET=change_this_to_something_random_and_long

# === MySQL database ===
# Railway provides MYSQL_URL automatically when you add a MySQL service.
# For Docker/VPS/local runs, use the DB_* values below.
MYSQL_URL=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=netvend
DB_USER=netvend
DB_PASSWORD=change_this_database_password

# === Admin login (change after first run!) ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# === MikroTik hAP lite RouterOS API ===
# Create a dedicated API user on the router (see README) - don't use your main admin.
MIKROTIK_HOST=192.168.88.1
MIKROTIK_USER=billing-api
MIKROTIK_PASSWORD=change_this_too
MIKROTIK_PORT=8728
# Set to true if you enabled API-SSL on the router instead (recommended, port usually 8729)
MIKROTIK_USE_TLS=false

# Name of the hotspot server profile on the router that new users get attached to
MIKROTIK_HOTSPOT_SERVER=hotspot1

# === Mobile money (manual reference confirmation mode) ===
# The number(s) customers should send money to - shown on the portal page.
MOMO_AIRTEL_NUMBER=0977000000
MOMO_MTN_NUMBER=0966000000
MOMO_ZAMTEL_NUMBER=0955000000
