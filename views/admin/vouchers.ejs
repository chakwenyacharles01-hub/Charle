<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Vouchers - NetVend</title>
  <link rel="icon" href="/img/icon.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="topbar">
    <div class="brand-lockup"><img src="/img/icon.png" alt="NetVend"><span class="word">Net<span class="accent">Vend</span></span></div>
    <div>
      <a href="/admin/dashboard">Dashboard</a>
      <a href="/admin/packages">Packages</a>
      <a href="/admin/vouchers">Vouchers</a>
      <a href="/admin/payments">Payments</a>
      <a href="/admin/router-status">Router</a>
    </div>
  </div>

  <div class="container">
    <div class="card">
      <h3>Generate Vouchers</h3>
      <p class="muted">Vouchers are only pushed to the router when redeemed (customer enters the code on the portal), so generating them here just prints codes for you to sell offline - nothing is created on the router yet.</p>
      <form method="POST" action="/admin/vouchers/generate">
        <label>Package</label>
        <select name="package_id" required>
          <% packages.forEach(p => { %>
            <option value="<%= p.id %>"><%= p.name %> - K<%= p.price.toFixed(2) %></option>
          <% }) %>
        </select>
        <label>Quantity</label>
        <input type="number" name="quantity" value="10" min="1" max="500" required>
        <button type="submit" style="margin-top:14px;">Generate</button>
      </form>
    </div>

    <div class="card">
      <h3>Recent Vouchers</h3>
      <table>
        <tr><th>Code</th><th>Package</th><th>Status</th><th>Created</th><th></th></tr>
        <% vouchers.forEach(v => { %>
          <tr>
            <td class="voucher-code" style="font-size:14px; padding:4px 10px;"><%= v.code %></td>
            <td><%= v.package_name %></td>
            <td><span class="badge <%= v.status %>"><%= v.status %></span></td>
            <td><%= v.created_at %></td>
            <td>
              <% if (v.status === 'unused') { %>
              <form class="inline" method="POST" action="/admin/vouchers/<%= v.code %>/push-to-router">
                <button type="submit" class="btn-secondary">Activate Now</button>
              </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </table>
    </div>
  </div>
</body>
</html>
